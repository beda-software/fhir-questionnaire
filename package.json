{
    "name": "@beda.software/fhir-questionnaire",
    "version": "2.0.0-alpha.0",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./components/*": {
            "types": "./dist/components/*.d.ts",
            "default": "./dist/components/*.js"
        },
        "./contexts/*": {
            "types": "./dist/contexts/*.d.ts",
            "default": "./dist/contexts/*.js"
        },
        "./services/*": {
            "types": "./dist/services/*.d.ts",
            "default": "./dist/services/*.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "peerDependencies": {
        "@types/react": "*",
        "react": "*",
        "typescript": "*"
    },
    "scripts": {
        "test": "vitest",
        "typecheck": "tsc --noEmit",
        "build": "tsc -p tsconfig.json",
        "extract": "lingui extract",
        "compile": "lingui compile --typescript",
        "prepare": "npm run compile && npm run build"
    },
    "dependencies": {
        "@beda.software/fhir-react": "^1.11.1",
        "@beda.software/remote-data": "^1.1.4",
        "@hookform/resolvers": "^3.1.1",
        "@lingui/core": "^4.3.0",
        "@lingui/macro": "^4.3.0",
        "@types/fhir": "^0.0.40",
        "@types/lodash": "^4.14.202",
        "axios": "^1.8.4",
        "fhirpath": "^3.18.0",
        "lodash": "^4.17.15",
        "moment": "^2.30.1",
        "query-string": "^7.1.1",
        "react-hook-form": "^7.49.3",
        "sdc-qrf": "1.1.0-alpha.1",
        "tslib": "^2.8.1",
        "yup": "^1.2.0"
    },
    "devDependencies": {
        "@lingui/cli": "^4.3.0",
        "@types/react": "^19.1.5",
        "eslint": "^9.23.0",
        "eslint-config-prettier": "^10.1.1",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.0",
        "prettier": "3.5.3",
        "react": "18.2.0",
        "react-dom": "18.2.0",
        "typescript": "^5.1.6",
        "typescript-eslint": "^8.28.0",
        "vitest": "^3.2.4"
    }
}
