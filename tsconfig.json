{
    "compilerOptions": {
        "target": "es6",
        "lib": ["DOM", "ES5", "DOM.Iterable", "ES2019"],
        "module": "esnext",
        "moduleResolution": "node",
        "importHelpers": true,
        "useDefineForClassFields": true,
        "isolatedModules": true,
        "strict": true,
        "jsx": "react-jsx",

        "allowJs": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": false,
        "noEmitOnError": true,

        "skipLibCheck": true,

        "outDir": "dist",

        "baseUrl": ".",
        "noUncheckedIndexedAccess": true,
        "noUnusedLocals": true,
        "resolveJsonModule": true,
        "esModuleInterop": true
    },
    "include": ["index.ts", "components/**/*", "contexts/**/*", "services/**/*"],
    "exclude": ["dist", "node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
